<UserControl x:Class="AppointmentManagementSystem.WpfClient.Views.AppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

	<Grid Background="White">

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="400"/>
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>


		<!-- TOP TOOLBAR -->
		<Grid Grid.Row="0"
              Grid.Column="0"
              Margin="20,15,20,15"
              Height="50"
              VerticalAlignment="Center">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<!-- Date Picker -->
			<DatePicker Grid.Column="0"
                        SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                        Width="150"
                        Padding="8"/>

			<!-- Reload Button -->
			<Button Grid.Column="1"
                    Command="{Binding LoadAppointmentsCommand}"
                    Padding="8,8"
                    Width="40"
                    Height="40"
                    Content="⟳"
                    Background="#4F7DF3"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="18"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Reload Appointments"
                    Margin="15,0,0,0"/>

			<!-- Add Appointment Button (Right Side) -->
			<Border Grid.Column="3"
                    Background="#10B981"
                    CornerRadius="6"
                    Padding="0">
				<Button Command="{Binding AddAppointmentCommand}"
                        Padding="16,10"
                        Background="Transparent"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand">
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
						<TextBlock Text="+" FontSize="18" FontWeight="Bold" Margin="0,0,8,0" Foreground="White"/>
						<TextBlock Text="Appointment" VerticalAlignment="Center" Foreground="White"/>
					</StackPanel>
				</Button>
			</Border>

		</Grid>


		<!-- LOADING -->
		<StackPanel Grid.Row="1"
                    Grid.Column="0"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

			<TextBlock Text="Loading appointments..."
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"
                       FontSize="16"
                       Foreground="Black"/>

		</StackPanel>


		<!-- TIMELINE APPOINTMENTS -->
		<ScrollViewer Grid.Row="1"
                      Grid.Column="0"
                      Margin="20"
                      Visibility="{Binding IsLoading, Converter={StaticResource InvertBoolToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

			<ItemsControl ItemsSource="{Binding Appointments}">

				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>


				<ItemsControl.ItemTemplate>
					<DataTemplate>

						<Grid Margin="0,0,0,14">

							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="80"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>


							<!-- TIME COLUMN -->
							<TextBlock Grid.Column="0"
                                       Text="{Binding StartTime, StringFormat={}{0:HH:mm}}"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       VerticalAlignment="Top"
                                       Foreground="Black"/>


							<!-- APPOINTMENT CARD BUTTON -->
							<Button Grid.Column="1"
                                    Command="{Binding DataContext.EditAppointmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">

								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="*"/>
									</Grid.RowDefinitions>

									<!-- APPOINTMENT CARD -->
									<Border Grid.Row="0"
                                            Background="White"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="16"
                                            Margin="0,0,0,0">

										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="Auto"/>
											</Grid.ColumnDefinitions>

											<!-- Card Content -->
											<StackPanel Grid.Column="0">

												<TextBlock
                                                    Text="{Binding Title}"
                                                    FontWeight="Bold"
                                                    FontSize="15"
                                                    Foreground="Black"/>

												<TextBlock
                                                    Text="{Binding PatientName, StringFormat=Patient: {0}}"
                                                    Margin="0,6,0,0"
                                                    Foreground="Black"
                                                    FontSize="14"/>

												<TextBlock
                                                    Margin="0,6,0,0"
                                                    FontSize="13"
                                                    Foreground="Black">
													<Run Text="{Binding StartTime, StringFormat={}{0:HH:mm}, Mode=OneWay}"/>
													<Run Text=" to "/>
													<Run Text="{Binding EndTime, StringFormat={}{0:HH:mm}, Mode=OneWay}"/>
												</TextBlock>

											</StackPanel>

											<!-- Delete Button -->
											<Button Grid.Column="1"
                                                    Content="Delete"
                                                    Command="{Binding DataContext.DeleteAppointmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#EF4444"
                                                    Foreground="White"
                                                    Padding="6,2"
                                                    FontSize="12"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    VerticalAlignment="Top"
                                                    Margin="8,0,0,0"/>

										</Grid>

									</Border>

								</Grid>

							</Button>

						</Grid>

					</DataTemplate>
				</ItemsControl.ItemTemplate>

			</ItemsControl>

		</ScrollViewer>


		<!-- ERROR MESSAGE -->
		<TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Margin="20,10,20,10"
                   TextWrapping="Wrap"
                   FontSize="12"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>


		<!-- RIGHT DRAWER PANEL -->
		<Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="1"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1,0,0,0"
                Visibility="{Binding IsDrawerOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                Padding="20">

			<ScrollViewer VerticalScrollBarVisibility="Auto">
				<StackPanel>

					<TextBlock FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,20"
                               Foreground="Black"
                               Text="{Binding SelectedAppointment, Converter={StaticResource SelectedAppointmentToHeaderConverter}}"/>

					<!-- Patient Field -->
					<TextBlock Text="Patient"
                               Margin="0,0,0,6"
                               Foreground="Black"
                               FontWeight="SemiBold"/>

					<!-- Patient ComboBox (for CREATE mode) -->
					<ComboBox ItemsSource="{Binding CreateViewModel.Patients}"
                              SelectedItem="{Binding CreateViewModel.SelectedPatient, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,14"
                              Padding="8,6"
                              Foreground="Black"
                              Background="White"
                              Visibility="{Binding SelectedAppointment, Converter={StaticResource NullToVisibilityConverter}}">
						<ComboBox.ItemContainerStyle>
							<Style TargetType="ComboBoxItem">
								<Setter Property="Foreground" Value="Black"/>
								<Setter Property="Background" Value="White"/>
							</Style>
						</ComboBox.ItemContainerStyle>
					</ComboBox>

					<!-- Patient Label (for EDIT mode) -->
					<TextBlock Text="{Binding SelectedAppointment.PatientName, FallbackValue=''}"
                               Margin="0,0,0,14"
                               Padding="8,6"
                               Foreground="Black"
                               FontSize="14"
                               Visibility="{Binding SelectedAppointment, Converter={StaticResource NotNullToVisibilityConverter}}"/>

					<!-- Title Field -->
					<TextBlock Text="Title"
                               Margin="0,0,0,6"
                               Foreground="Black"
                               FontWeight="SemiBold"/>
					<TextBox Text="{Binding CreateViewModel.Title, Mode=TwoWay}"
                             Margin="0,0,0,14"
                             Padding="8,6"
                             Foreground="Black"
                             Background="White"
                             BorderBrush="#E5E7EB"
                             BorderThickness="1"/>

					<!-- Start Time Field -->
					<TextBlock Text="Start Time"
                               Margin="0,0,0,6"
                               Foreground="Black"
                               FontWeight="SemiBold"/>
					<Grid Margin="0,0,0,14">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="100"/>
						</Grid.ColumnDefinitions>
						<DatePicker Grid.Column="0"
                                    SelectedDate="{Binding CreateViewModel.StartTime, Mode=TwoWay, Converter={StaticResource DateTimeOffsetToDateTimeConverter}}"
                                    Padding="8,6"
                                    Foreground="Black"
                                    Background="White"
                                    Margin="0,0,8,0"/>
						<TextBox Grid.Column="1"
                                 Text="00:00"
                                 Padding="8,6"
                                 Foreground="Black"
                                 Background="White"
                                 BorderBrush="#D1D5DB"
                                 BorderThickness="1"
                                 TextAlignment="Center"
                                 ToolTip="HH:MM format"/>
					</Grid>

					<!-- End Time Field -->
					<TextBlock Text="End Time"
                               Margin="0,0,0,6"
                               Foreground="Black"
                               FontWeight="SemiBold"/>
					<Grid Margin="0,0,0,14">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="100"/>
						</Grid.ColumnDefinitions>
						<DatePicker Grid.Column="0"
                                    SelectedDate="{Binding CreateViewModel.EndTime, Mode=TwoWay, Converter={StaticResource DateTimeOffsetToDateTimeConverter}}"
                                    Padding="8,6"
                                    Foreground="Black"
                                    Background="White"
                                    Margin="0,0,8,0"/>
						<TextBox Grid.Column="1"
                                 Text="00:00"
                                 Padding="8,6"
                                 Foreground="Black"
                                 Background="White"
                                 BorderBrush="#D1D5DB"
                                 BorderThickness="1"
                                 TextAlignment="Center"
                                 ToolTip="HH:MM format"/>
					</Grid>

					<!-- Notes Field -->
					<TextBlock Text="Notes"
                               Margin="0,0,0,6"
                               Foreground="Black"
                               FontWeight="SemiBold"/>
					<TextBox Text="{Binding CreateViewModel.Notes, Mode=TwoWay}"
                             AcceptsReturn="True"
                             Height="100"
                             Margin="0,0,0,20"
                             Padding="8,6"
                             Foreground="Black"
                             Background="White"
                             BorderBrush="#E5E7EB"
                             BorderThickness="1"
                             VerticalAlignment="Top"/>

					<!-- Buttons -->
					<StackPanel Orientation="Horizontal" Margin="0,20,0,0">
						<Button Content="Save"
                                Command="{Binding CreateViewModel.CreateCommand}"
                                Padding="12,8"
                                Background="#4F7DF3"
                                Foreground="White"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Width="100"
                                Margin="0,0,10,0"/>
						<Button Content="Cancel"
                                Command="{Binding CloseDrawerCommand}"
                                Padding="12,8"
                                Background="#E5E7EB"
                                Foreground="Black"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Width="100"/>
					</StackPanel>

					<!-- Error Message in Drawer -->
					<TextBlock Text="{Binding CreateViewModel.ErrorMessage}"
                               Foreground="Red"
                               Margin="0,15,0,0"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Visibility="{Binding CreateViewModel.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

				</StackPanel>
			</ScrollViewer>

		</Border>

	</Grid>

</UserControl>