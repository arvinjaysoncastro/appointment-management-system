<UserControl x:Class="AppointmentManagementSystem.WpfClient.Views.AppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar with Date Picker and Buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,15,20,15" Height="50" VerticalAlignment="Center">
            <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                        Width="150"
                        Margin="0,0,15,0"
                        Padding="8"/>
            <Button Command="{Binding LoadAppointmentsCommand}" 
                    Padding="15,10"
                    Width="150"
                    Content="Load Appointments"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="SemiBold"/>
            <Button Command="{Binding AddAppointmentCommand}" 
                    Padding="15,10"
                    Margin="10,0,0,0"
                    Width="150"
                    Content="Add Appointment"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Loading Indicator -->
        <StackPanel Grid.Row="1"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock Text="Loading appointments..." 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"
                       FontSize="16"/>
        </StackPanel>

        <!-- Appointments DataGrid -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Appointments}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Visibility="{Binding IsLoading, Converter={StaticResource InvertBoolToVisibilityConverter}}"
                  Margin="20"
                  BorderThickness="1"
                  BorderBrush="#E0E0E0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" 
                                    Binding="{Binding Id}" 
                                    Width="200"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Patient Name" 
                                    Binding="{Binding PatientName}" 
                                    Width="150"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Title" 
                                    Binding="{Binding Title}" 
                                    Width="150"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Start Time" 
                                    Binding="{Binding StartTime, StringFormat='g'}" 
                                    Width="180"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="End Time" 
                                    Binding="{Binding EndTime, StringFormat='g'}" 
                                    Width="180"
                                    IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Error Message -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Margin="20,10,20,10"
                   TextWrapping="Wrap"
                   FontSize="12"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
    </Grid>
</UserControl>
