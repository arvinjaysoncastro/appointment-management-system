<Window x:Class="AppointmentManagementSystem.WpfClient.Views.AppointmentCreateView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Create Appointment" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="White"
        Padding="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Create New Appointment" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Patient ID -->
        <TextBlock Grid.Row="1" Text="Patient ID:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" 
                 Text="{Binding PatientId, UpdateSourceTrigger=PropertyChanged}" 
                 Padding="8"
                 Margin="0,0,0,15"/>

        <!-- Title -->
        <TextBlock Grid.Row="3" Text="Appointment Title:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="4" 
                 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                 Padding="8"
                 Margin="0,0,0,15"/>

        <!-- Start Time -->
        <TextBlock Grid.Row="5" Text="Start Time:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="6" 
                 Text="{Binding StartTime, StringFormat='g', UpdateSourceTrigger=PropertyChanged}" 
                 Padding="8"
                 Margin="0,0,0,15"/>

        <!-- End Time -->
        <TextBlock Grid.Row="7" Text="End Time:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="8" 
                 Text="{Binding EndTime, StringFormat='g', UpdateSourceTrigger=PropertyChanged}" 
                 Padding="8"
                 Margin="0,0,0,15"/>

        <!-- Notes -->
        <TextBlock Grid.Row="9" Text="Notes:" Margin="0,0,0,5"/>

        <!-- Notes Text Box -->
        <TextBox Grid.Row="10" 
                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                 Padding="8"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,15"/>

        <!-- Error Message -->
        <TextBlock Grid.Row="11"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Command="{Binding CreateCommand}"
                    Content="Create"
                    Padding="15,8"
                    Margin="0,0,10,0"
                    Background="#4CAF50"
                    Foreground="White"
                    IsEnabled="{Binding IsSubmitting, Converter={StaticResource BooleanInvertConverter}}"/>
            <Button Command="{Binding CancelCommand}"
                    Content="Cancel"
                    Padding="15,8"
                    Background="#f44336"
                    Foreground="White"
                    IsEnabled="{Binding IsSubmitting, Converter={StaticResource BooleanInvertConverter}}"/>
        </StackPanel>
    </Grid>
</Window>
